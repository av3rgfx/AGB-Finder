{
  "name": "ufptrade",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx --env-file-if-exists=.env prisma/seed.ts",
    "db:seed:catalog": "tsx --env-file-if-exists=.env prisma/seed-catalog.ts",
    "db:seed:kit": "tsx --env-file-if-exists=.env prisma/seed-kit.ts",
    "db:studio": "prisma studio",
    "import:agb": "tsx --env-file-if-exists=.env scripts/import-agb.ts",
    "embed:products": "tsx --env-file-if-exists=.env scripts/embed-products.ts",
    "backfill:pages": "tsx --env-file-if-exists=.env scripts/backfill-listino-pages.ts",
    "split:listino": "tsx --env-file-if-exists=.env scripts/split-listino.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@prisma/client": "^6.5.0",
    "@tanstack/react-query": "^5.66.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.6.23",
    "clsx": "^2.1.1",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.475.0",
    "next": "15.5.20",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-pdf": "^10.4.1",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vercel/blob": "^2.6.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.20",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "next-auth>react": "$react",
      "next-auth>react-dom": "$react-dom",
      "better-call": "1.3.7",
      "@better-fetch/fetch": "1.3.1"
    },
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
