# ═══════════════════════════════════════════════════════════════
# DATABASE (Neon in prod / local Postgres+pgvector in dev)
# Neon: DATABASE_URL = connessione POOLED (host con -pooler, ?sslmode=require&pgbouncer=true)
#       DIRECT_URL   = connessione DIRETTA (host senza -pooler, ?sslmode=require) — per le migrazioni
# ═══════════════════════════════════════════════════════════════
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/utpistoia?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/utpistoia?schema=public"

# ═══════════════════════════════════════════════════════════════
# REDIS (Upstash in prod / local Redis in dev)
# ═══════════════════════════════════════════════════════════════
REDIS_URL="redis://localhost:6379"

# ═══════════════════════════════════════════════════════════════
# AUTH (Better Auth — le var mantengono i nomi NEXTAUTH_* per compat)
# In produzione: NEXTAUTH_URL = URL Vercel reale (es. https://catalogo-finder.vercel.app)
# ═══════════════════════════════════════════════════════════════
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-min-32-chars-run-openssl-rand-base64-32"

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS (optional in Fase 1 Fondamenta)
# ═══════════════════════════════════════════════════════════════
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
KIMI_API_KEY=""
KIMI_MODEL="kimi-k2.6"

# ═══════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════
IP_HASH_SECRET="change-me-run-openssl-rand-base64-32"

# Master key per la cifratura delle API key AI salvate a DB (/impostazioni).
# Opzionale in dev/CI; se assente, la feature "key da DB" è disattiva.
# Genera: openssl rand -base64 32 — distinta per ambiente, mai loggata.
SETTINGS_ENCRYPTION_KEY=""

# ═══════════════════════════════════════════════════════════════
# LISTINO VIEWER (feature «visualizza nel listino», Opzione B: pagine singole su Vercel Blob PRIVATO)
# Popolate dallo split (ops-split-listino.yml → scripts/split-listino.ts). Assenti = feature off.
# BLOB_READ_WRITE_TOKEN: token dello store Blob (Vercel → Storage → Blob → Tokens). La route legge
#                        le paginette private lato server con questo token; è anche il nome che l'SDK
#                        @vercel/blob usa di default. NON esporre mai al client.
# LISTINO_TOTAL_PAGES:   numero totale di pagine del listino (per prev/next del viewer)
# Lasciare COMMENTATE per tenere la feature off (LISTINO_TOTAL_PAGES vuoto non è un numero valido).
# ═══════════════════════════════════════════════════════════════
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"
# LISTINO_TOTAL_PAGES="959"

# ═══════════════════════════════════════════════════════════════
# SEED (admin bootstrap — used by prisma/seed.ts)
# ═══════════════════════════════════════════════════════════════
SEED_ADMIN_EMAIL="admin@utensilferramenta.it"
SEED_ADMIN_PASSWORD="change-me-strong-password"

# ═══════════════════════════════════════════════════════════════
# PRISMA ENGINES (sandbox workaround — set by scripts/setup-prisma-engines.sh)
# Leave unset in normal environments where Prisma can download engines.
# ═══════════════════════════════════════════════════════════════
# PRISMA_QUERY_ENGINE_LIBRARY=""
# PRISMA_SCHEMA_ENGINE_BINARY=""
# PRISMA_CLI_QUERY_ENGINE_TYPE="library"
# NODE_EXTRA_CA_CERTS=""
