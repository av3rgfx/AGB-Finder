# ═══════════════════════════════════════════════════════════════
# DATABASE (Neon in prod / local Postgres+pgvector in dev)
# ═══════════════════════════════════════════════════════════════
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/utpistoia?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/utpistoia?schema=public"

# ═══════════════════════════════════════════════════════════════
# REDIS (Upstash in prod / local Redis in dev)
# ═══════════════════════════════════════════════════════════════
REDIS_URL="redis://localhost:6379"

# ═══════════════════════════════════════════════════════════════
# AUTH (NextAuth v4)
# ═══════════════════════════════════════════════════════════════
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-min-32-chars-run-openssl-rand-base64-32"

# ═══════════════════════════════════════════════════════════════
# AI PROVIDERS (optional in Fase 1 Fondamenta)
# ═══════════════════════════════════════════════════════════════
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
KIMI_API_KEY=""
KIMI_MODEL="kimi-k2.6"

# ═══════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════
IP_HASH_SECRET="change-me-run-openssl-rand-base64-32"

# ═══════════════════════════════════════════════════════════════
# SEED (admin bootstrap — used by prisma/seed.ts)
# ═══════════════════════════════════════════════════════════════
SEED_ADMIN_EMAIL="admin@utensilferramenta.it"
SEED_ADMIN_PASSWORD="change-me-strong-password"

# ═══════════════════════════════════════════════════════════════
# PRISMA ENGINES (sandbox workaround — set by scripts/setup-prisma-engines.sh)
# Leave unset in normal environments where Prisma can download engines.
# ═══════════════════════════════════════════════════════════════
# PRISMA_QUERY_ENGINE_LIBRARY=""
# PRISMA_SCHEMA_ENGINE_BINARY=""
# PRISMA_CLI_QUERY_ENGINE_TYPE="library"
# NODE_EXTRA_CA_CERTS=""
